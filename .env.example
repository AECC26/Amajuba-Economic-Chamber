# ── Server-side secrets (never exposed to the browser) ──────────────────────
# Set these in your hosting provider's environment variable settings.

# Together AI — used by the /api/chat proxy endpoint in server.js
TOGETHER_API_KEY="your-together-api-key"
TOGETHER_MODEL="openai/gpt-oss-20b"

# Supabase service role key — used by the /api/update-profile endpoint
# WARNING: never use the service role key in client-side (VITE_) variables
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_REGISTRATIONS_TABLE="registrations"

# ── Client-side variables (bundled into the browser build) ───────────────────
# Only the anon key belongs here — it is safe to expose (protected by RLS).

VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_SUPABASE_REGISTRATIONS_TABLE="registrations"
VITE_SUPABASE_STORAGE_BUCKET="Registrations"

# Optional
VITE_APP_URL="http://localhost:5000"
